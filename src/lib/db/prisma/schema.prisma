generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ACCOUNTANT
  FINANCE_ADMIN
  AUDITOR
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  DRAFT
  PENDING
  APPROVED
  EXECUTED
  REJECTED
  REVERSED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum ReconciliationStatus {
  UNRECONCILED
  RECONCILED
  EXCEPTION
}

enum LedgerEntryType {
  EXPENSE
  INCOME
  TRANSFER
  ADJUSTMENT
  REVERSAL
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  fullName     String
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions Transaction[]
  approvals    Approval[]        @relation("Approver")
  uploadedAttachments TransactionAttachment[] @relation("AttachmentUploader")
  recurringTransactions RecurringTransaction[] @relation("RecurringCreator")
  reconciledLedgerEntries LedgerEntry[] @relation("LedgerReconciler")
  ledgerEntries LedgerEntry[]
  budgetTransfers BudgetTransfer[]
  auditLogs    AuditLog[]

  @@index([role])
}

model Department {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  budgetAllocated Decimal  @db.Decimal(18, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budgets               Budget[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
}

model Budget {
  id             String   @id @default(uuid())
  departmentId   String
  period         String
  amount         Decimal  @db.Decimal(18, 2)
  reserved       Decimal  @default(0) @db.Decimal(18, 2)
  used           Decimal  @default(0) @db.Decimal(18, 2)
  parentBudgetId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  department        Department           @relation(fields: [departmentId], references: [id])
  parentBudget      Budget?              @relation("BudgetHierarchy", fields: [parentBudgetId], references: [id])
  childBudgets      Budget[]             @relation("BudgetHierarchy")
  outgoingTransfers BudgetTransfer[]     @relation("TransferFromBudget")
  incomingTransfers BudgetTransfer[]     @relation("TransferToBudget")
  policies              BudgetControlPolicy[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]

  @@unique([departmentId, period])
  @@index([departmentId])
  @@index([parentBudgetId])
}

model Transaction {
  id          String            @id @default(uuid())
  code        String            @unique
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(18, 2)
  currency    String            @default("VND")
  date        DateTime
  description String?

  fxCurrency        String?
  fxAmount          Decimal? @db.Decimal(18, 2)
  fxRate            Decimal? @db.Decimal(18, 6)
  baseCurrency      String?
  baseAmount        Decimal? @db.Decimal(18, 2)
  fxRateProvider    String?
  fxRateFetchedAt   DateTime?

  recurringSourceId String?
  budgetId          String?
  departmentId      String?
  createdById       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recurringSource RecurringTransaction? @relation(fields: [recurringSourceId], references: [id])
  budget          Budget?               @relation(fields: [budgetId], references: [id])
  department      Department?           @relation(fields: [departmentId], references: [id])
  createdBy       User                  @relation(fields: [createdById], references: [id])

  approvals   Approval[]
  postings    CashbookPosting[]
  attachments TransactionAttachment[]
  splits      TransactionSplit[]

  @@index([recurringSourceId])
  @@index([budgetId])
  @@index([departmentId])
  @@index([status])
  @@index([date])
}

model Approval {
  id            String   @id @default(uuid())
  transactionId String
  approverId    String
  step          Int      @default(1)
  status        String
  statusV2      ApprovalStatus?
  note          String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
  approver    User        @relation("Approver", fields: [approverId], references: [id])

  @@index([transactionId, step])
  @@index([approverId, status])
  @@index([approverId, statusV2])
}

model CashbookAccount {
  id        String   @id @default(uuid())
  name      String
  type      String
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postings CashbookPosting[]
}

model CashbookPosting {
  id            String   @id @default(uuid())
  accountId     String
  transactionId String
  direction     String
  amount        Decimal  @db.Decimal(18, 2)
  postedAt      DateTime @default(now())

  account     CashbookAccount @relation(fields: [accountId], references: [id])
  transaction Transaction     @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
}

model LedgerEntry {
  id            String          @id @default(uuid())
  entryCode     String          @unique
  type          LedgerEntryType
  amount        Decimal         @db.Decimal(18, 2)
  currency      String          @default("VND")
  referenceType String
  referenceId   String
  metadata      Json?
  reversalOfId  String?
  createdById   String

  fxCurrency      String?
  fxAmount        Decimal? @db.Decimal(18, 2)
  fxRate          Decimal? @db.Decimal(18, 6)
  baseCurrency    String?
  baseAmount      Decimal? @db.Decimal(18, 2)
  fxRateProvider  String?
  fxRateFetchedAt DateTime?

  reconciliationStatus ReconciliationStatus @default(UNRECONCILED)
  reconciledAt         DateTime?
  reconciledById       String?
  reconciliationRef    String?

  createdAt     DateTime        @default(now())

  createdBy User @relation(fields: [createdById], references: [id])
  reconciledBy User? @relation("LedgerReconciler", fields: [reconciledById], references: [id])
  reversalOf LedgerEntry? @relation("LedgerReversal", fields: [reversalOfId], references: [id])
  reversals LedgerEntry[] @relation("LedgerReversal")

  @@index([referenceType, referenceId])
  @@index([reconciliationStatus])
  @@index([reconciledById])
  @@index([createdAt])
  @@unique([reversalOfId], map: "ledger_unique_reversal_target")
}

model BudgetTransfer {
  id             String   @id @default(uuid())
  fromBudgetId   String
  toBudgetId     String
  amount         Decimal  @db.Decimal(18, 2)
  reason         String?
  idempotencyKey String   @unique
  createdById    String
  createdAt      DateTime @default(now())

  fromBudget Budget @relation("TransferFromBudget", fields: [fromBudgetId], references: [id])
  toBudget   Budget @relation("TransferToBudget", fields: [toBudgetId], references: [id])
  createdBy  User   @relation(fields: [createdById], references: [id])

  @@index([fromBudgetId])
  @@index([toBudgetId])
  @@index([createdAt])
}

model Reimbursement {
  id             String   @id @default(uuid())
  employeeId     String
  advanceAmount  Decimal  @db.Decimal(18, 2)
  actualAmount   Decimal? @db.Decimal(18, 2)
  netAmount      Decimal? @db.Decimal(18, 2)
  settledAt      DateTime?
  createdAt      DateTime @default(now())
}

model RecurringTransaction {
  id           String             @id @default(uuid())
  name         String
  type         TransactionType
  amount       Decimal            @db.Decimal(18, 2)
  currency     String             @default("VND")
  frequency    RecurringFrequency
  nextRunAt    DateTime
  lastRunAt    DateTime?
  active       Boolean            @default(true)
  budgetId     String?
  departmentId String?
  createdById  String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  budget       Budget?            @relation(fields: [budgetId], references: [id])
  department   Department?        @relation(fields: [departmentId], references: [id])
  createdBy    User               @relation("RecurringCreator", fields: [createdById], references: [id])
  transactions Transaction[]

  @@index([active, nextRunAt])
  @@index([budgetId])
  @@index([departmentId])
}

model TransactionAttachment {
  id            String   @id @default(uuid())
  transactionId String
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  uploadedById  String
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
  uploadedBy  User        @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  @@index([transactionId, createdAt])
  @@index([uploadedById])
}

model TransactionSplit {
  id            String   @id @default(uuid())
  transactionId String
  amount        Decimal  @db.Decimal(18, 2)
  categoryCode  String?
  note          String?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
}

model BudgetControlPolicy {
  id                  String   @id @default(uuid())
  budgetId            String?
  warningThresholdPct Int      @default(80)
  hardStopEnabled     Boolean  @default(true)
  createdById         String?
  updatedById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  budget Budget? @relation(fields: [budgetId], references: [id])

  @@unique([budgetId])
}

model AuditLog {
  id            String   @id @default(uuid())
  actorId       String
  action        String
  entityType    String
  entityId      String
  result        String   @default("SUCCESS")
  correlationId String?
  payload       Json?
  createdAt     DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@index([correlationId])
}
