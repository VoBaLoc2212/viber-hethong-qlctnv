# =========================
# Core App Configuration
# =========================
NODE_ENV=development
APP_NAME=Budget Management System
APP_ENV=development
PORT=3001
LOG_LEVEL=info
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# =========================
# Database
# =========================
DATABASE_URL=postgresql://budget_user:budget_password@157.66.46.69:5432/budget_qlctnv
PRISMA_DATABASE_URL=postgresql://budget_user:budget_password@157.66.46.69:5432/budget_qlctnv

# =========================
# Auth / Security
# =========================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# =========================
# Email (Budget alerts)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDER_EMAIL=noreply@company.com

# =========================
# Storage (S3-compatible)
# =========================
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-southeast-1
S3_BUCKET=budget-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
TRANSACTION_ATTACHMENT_MAX_FILE_SIZE_BYTES=10485760
TRANSACTION_ATTACHMENT_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp

# =========================
# Recurring Scheduler
# =========================
# Cách bật auto thực tế:    
# Set CRON_SECRET và RECURRING_CRON_ACTOR_USER_ID (ID user đang active, role ACCOUNTANT hoặc FINANCE_ADMIN) theo logic ở buildSystemAuthContext().
# Trên Vercel, đảm bảo cron gửi Authorization: Bearer <CRON_SECRET> tới route POST().
RECURRING_SCHEDULER_ENABLED=true
RECURRING_SCHEDULER_INTERVAL_MS=60000
CRON_SECRET=change-this-strong-secret
RECURRING_CRON_ACTOR_USER_ID=

# =========================
# OpenAPI / Contract
# =========================
OPENAPI_PATH=src/lib/api-spec/openapi.yaml

# =========================
# AI / Chatbot
# =========================
AI_CHAT_ENDPOINT=
AI_CHAT_BASE_URL=
AI_CHAT_API_KEY=
AI_CHAT_MODEL=
AI_TEMPERATURE=0.2
AI_TIMEOUT_MS=30000

# =========================
# Redis (REST API style)
# =========================
REDIS_URL=
REDIS_TOKEN=
REDIS_PREFIX=budget-ai
REDIS_TTL_INTENT_SEC=300
REDIS_TTL_SQL_SEC=180
REDIS_TTL_RAG_SEC=600
