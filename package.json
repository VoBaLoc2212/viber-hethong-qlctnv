{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "next dev src --port 3001",
    "build": "npm run typecheck && next build src",
    "start": "npm run prisma:generate && next start src --port 3001",
    "typecheck": "npm run prisma:generate && tsc -p src/tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema src/lib/db/prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema src/lib/db/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema src/lib/db/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema src/lib/db/prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema src/lib/db/prisma/schema.prisma",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "validation:cleanup-runtime": "tsx scripts/validation/cleanup-runtime-validation.ts",
    "validation:ai:gemini-connectivity": "tsx scripts/validation/verify-gemini-connectivity.ts",
    "validation:ai:routes": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validation/verify-ai-routes.ps1",
    "validation:ai:orchestrator-gemini": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validation/verify-chat-orchestrator-gemini.ps1",
    "validation:ai:question-matrix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validation/verify-ai-role-question-matrix.ps1",
    "validation:ai:question-matrix:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validation/verify-ai-role-question-matrix.ps1 -Smoke",
    "validation:ai:question-matrix:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validation/verify-ai-role-question-matrix.ps1 -Strict",
    "validation:ai:context-history-cache": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validation/verify-ai-context-history-cache.ps1",
    "validation:ai:context-history-cache:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validation/verify-ai-context-history-cache.ps1 -Smoke",
    "validation:data:cross-module-consistency": "tsx scripts/validation/verify-cross-module-consistency.ts",
    "postinstall": "npm run prisma:generate"
  },
  "private": true,
  "dependencies": {
    "@google/genai": "^1.23.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.13.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.95.2",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.6.0",
    "mammoth": "^1.12.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4.7.6",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "next": "^16.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prisma": "^6.13.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "tsx src/lib/db/prisma/seed.ts"
  }
}
