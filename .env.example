# =========================
# Core App Configuration
# =========================
NODE_ENV=development
APP_NAME=Budget Management System
APP_ENV=development
PORT=3001
LOG_LEVEL=info
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# =========================
# Database
# =========================
DATABASE_URL=postgresql://budget_user:budget_password@postgres:5432/budget_qlctnv
PRISMA_DATABASE_URL=postgresql://budget_user:budget_password@postgres:5432/budget_qlctnv

# =========================
# Auth / Security
# =========================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# =========================
# Email (Budget alerts)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDER_EMAIL=noreply@company.com

# =========================
# Storage (S3-compatible)
# =========================
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-southeast-1
S3_BUCKET=budget-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# =========================
# OpenAPI / Contract
# =========================
OPENAPI_PATH=src/lib/api-spec/openapi.yaml
